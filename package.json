{
  "name": "@paybond/kit",
  "version": "0.11.2",
  "mcpName": "io.github.nonameuserd/paybond",
  "description": "Paybond Kit for TypeScript: agent spend governance for paid tool calls with spend authorization, evidence receipts, refunds, disputes, hosted Gateway sessions, and settlement.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "paybond": "dist/cli.js",
    "paybond-kit-login": "dist/login.js",
    "paybond-init": "dist/init.js",
    "paybond-mcp-server": "dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./openai-agents": {
      "types": "./dist/openai-agents/index.d.ts",
      "import": "./dist/openai-agents/index.js"
    },
    "./vercel-ai": {
      "types": "./dist/vercel-ai/index.d.ts",
      "import": "./dist/vercel-ai/index.js"
    },
    "./langgraph": {
      "types": "./dist/langgraph/index.d.ts",
      "import": "./dist/langgraph/index.js"
    },
    "./claude-agents": {
      "types": "./dist/claude-agents/index.d.ts",
      "import": "./dist/claude-agents/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    }
  },
  "files": [
    "dist",
    "completion-presets",
    "solutions",
    "templates",
    "dev",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonameuserd/paybond-kit.git"
  },
  "homepage": "https://github.com/nonameuserd/paybond-kit",
  "bugs": {
    "url": "https://github.com/nonameuserd/paybond-kit/issues"
  },
  "keywords": [
    "paybond",
    "harbor",
    "kit",
    "agents",
    "agent-runtime",
    "agent-spend-governance",
    "agent-spend-controls",
    "ai-agent-budget",
    "paid-tool-calls",
    "spend-authorization",
    "evidence-receipts",
    "refunds",
    "disputes",
    "delegated-spend",
    "spend-guardrails",
    "tool-call-spend-limits",
    "gemini",
    "claude",
    "anthropic",
    "agent-payments",
    "escrow",
    "intent-escrow",
    "capabilities",
    "capability-verification",
    "tenant-bound",
    "x402",
    "usdc",
    "mcp",
    "reputation",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.json && node ../scripts/sync-completion-catalog.mjs && node ../scripts/sync-dev-trace-ui.mjs && node ./scripts/generate-templates.mjs",
    "cli": "node dist/cli.js",
    "cli:dev": "npm run build --silent && node dist/cli.js",
    "generate:cli-contract": "node ../cli-parity/generate.mjs",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "verify:release": "node ./scripts/verify-release.mjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.100",
    "@langchain/core": ">=0.3.0",
    "@langchain/langgraph": ">=0.2.50",
    "@openai/agents": ">=0.12.0",
    "ai": ">=4.0.0",
    "zod": "^3.25.32 || ^4.2.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.1",
    "@noble/hashes": "^1.7.1",
    "@noble/secp256k1": "^2.2.3",
    "ajv": "^8.17.1",
    "blake3": "^2.1.7",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.197",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-sdk": "^1.9.25",
    "@openai/agents": "^0.12.0",
    "@types/node": "^22.10.0",
    "ai": "^7.0.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
